{
  "compilerOptions": {
    "outDir": "./lib",
    "target": "ES2020",
    "module": "commonjs",
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "sourceMap": true,
    "jsx": "react-jsx"
  },
  "include": [
    "./src/**/*.tsx",
    "./src/**/*.ts",
    "./tests/**/*.tsx",
    "./tests/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
