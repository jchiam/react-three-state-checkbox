{
  "name": "react-three-state-checkbox",
  "version": "3.0.0",
  "description": "React component for checkbox that supports the indeterminate state conveniently.",
  "main": "lib/src/index.js",
  "types": "lib/src/index.d.ts",
  "sideEffects": false,
  "scripts": {
    "build": "rm -rf ./lib && tsc",
    "prepare": "is-ci || husky",
    "test": "rm -rf .nyc_output && playwright test --config=playwright-ct.config.mjs",
    "test:ui": "rm -rf .nyc_output && playwright test --config=playwright-ct.config.mjs --ui",
    "lint": "eslint ./src"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jchiam/react-three-state-checkbox.git"
  },
  "keywords": [
    "react",
    "typescript",
    "checkbox",
    "indeterminate"
  ],
  "author": "Jonathan Chiam",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/jchiam/react-three-state-checkbox/issues"
  },
  "homepage": "https://github.com/jchiam/react-three-state-checkbox#readme",
  "engines": {
    "node": ">=22"
  },
  "files": [
    "lib",
    "src",
    "LICENSE"
  ],
  "devDependencies": {
    "@jchiam/eslint-config": "^5.0.2",
    "@playwright/experimental-ct-react": "^1.59.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.0",
    "husky": "^9.1.7",
    "is-ci": "^4.1.0",
    "istanbul-lib-coverage": "^3.2.2",
    "istanbul-lib-report": "^3.0.1",
    "istanbul-reports": "^3.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.0.0",
    "vite": "^7.3.1",
    "vite-plugin-istanbul": "^8.0.0"
  },
  "peerDependencies": {
    "react": "18 || 19",
    "react-dom": "18 || 19"
  }
}
