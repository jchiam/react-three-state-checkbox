{
  "name": "react-three-state-checkbox",
  "version": "3.0.0",
  "description": "React component for checkbox that supports the indeterminate state conveniently.",
  "main": "lib/src/index.js",
  "types": "lib/src/index.d.ts",
  "sideEffects": false,
  "scripts": {
    "build": "rm -rf ./lib && tsc",
    "prepare": "is-ci || husky",
    "test": "jest --coverage",
    "lint": "eslint ./src"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jchiam/react-three-state-checkbox.git"
  },
  "keywords": [
    "react",
    "typescript",
    "checkbox",
    "indeterminate"
  ],
  "author": "Jonathan Chiam",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/jchiam/react-three-state-checkbox/issues"
  },
  "homepage": "https://github.com/jchiam/react-three-state-checkbox#readme",
  "engines": {
    "node": ">=22"
  },
  "files": [
    "lib",
    "LICENSE"
  ],
  "jest": {
    "testEnvironment": "jest-environment-jsdom",
    "setupFilesAfterEnv": [
      "<rootDir>/tests/utils/jestSetup.js"
    ],
    "collectCoverage": true,
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js"
    ],
    "transform": {
      "^.+\\.(ts|tsx)$": "ts-jest"
    },
    "testMatch": [
      "**/*spec.(ts|tsx)"
    ]
  },
  "devDependencies": {
    "@jchiam/eslint-config": "^5.0.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.16",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.0.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.0",
    "husky": "^9.1.7",
    "is-ci": "^3.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "ts-jest": "^29.2.4",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0"
  },
  "peerDependencies": {
    "react": "18 || 19",
    "react-dom": "18 || 19"
  }
}
